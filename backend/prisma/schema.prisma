generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  perfil    String
  filialId  String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  filial Filial? @relation(fields: [filialId], references: [id])

  @@map("usuarios")
}

// ─────────────────────────────────────────────
// RECEPÇÃO
// ─────────────────────────────────────────────

model Cliente {
  id        String   @id @default(uuid())
  nome      String
  cpfCnpj   String?  @unique
  telefone  String
  email     String?
  genero    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  veiculos     Veiculo[]
  agendamentos Agendamento[]

  @@map("clientes")
}

model Veiculo {
  id        String  @id @default(uuid())
  clienteId String
  placa     String  @unique
  marca     String
  modelo    String
  ano       Int
  cor       String?
  km        Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cliente      Cliente        @relation(fields: [clienteId], references: [id])
  agendamentos Agendamento[]
  ordens       OrdemServico[]
  manutencoes  ManutencaoVeiculo[]

  @@map("veiculos")
}

model Agendamento {
  id          String   @id @default(uuid())
  clienteId   String
  veiculoId   String?
  dataHora    DateTime
  tipoServico String
  queixa      String?
  status      String   @default("PENDENTE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cliente Cliente      @relation(fields: [clienteId], references: [id])
  veiculo Veiculo?     @relation(fields: [veiculoId], references: [id])
  os      OrdemServico?

  @@map("agendamentos")
}

// ─────────────────────────────────────────────
// ORDEM DE SERVIÇO
// ─────────────────────────────────────────────

model OrdemServico {
  id            String    @id @default(uuid())
  numero        Int       @unique
  veiculoId     String
  agendamentoId String?   @unique
  filialId      String?
  servicoId     String?
  queixa        String
  status        String    @default("RECEPCAO")
  portalToken   String?   @unique
  valorTotal    Decimal   @default(0)
  valorPago     Decimal   @default(0)
  observacoes   String?
  dataEntrada   DateTime  @default(now())
  dataPrevista  DateTime?
  dataEntrega   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  veiculo     Veiculo        @relation(fields: [veiculoId], references: [id])
  agendamento Agendamento?   @relation(fields: [agendamentoId], references: [id])
  filial      Filial?        @relation(fields: [filialId], references: [id])
  servico     Servico?       @relation(fields: [servicoId], references: [id])
  checklist   ChecklistItem[]
  diagnostico Diagnostico?
  orcamento   Orcamento?
  itens       ItemOS[]
  pagamentos  Pagamento[]
  historico   HistoricoOS[]
  avaliacao   Avaliacao?
  sugestoesIA SugestaoIA[]

  @@map("ordens_servico")
}

model ChecklistItem {
  id    String  @id @default(uuid())
  osId  String
  campo String
  valor Boolean
  obs   String?

  os OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@map("checklist_itens")
}

model Diagnostico {
  id          String   @id @default(uuid())
  osId        String   @unique
  descricao   String
  tecnicoNome String?
  createdAt   DateTime @default(now())

  os    OrdemServico      @relation(fields: [osId], references: [id], onDelete: Cascade)
  fotos FotoDiagnostico[]

  @@map("diagnosticos")
}

model FotoDiagnostico {
  id            String      @id @default(uuid())
  diagnosticoId String
  filename      String
  createdAt     DateTime    @default(now())

  diagnostico Diagnostico @relation(fields: [diagnosticoId], references: [id], onDelete: Cascade)

  @@map("fotos_diagnostico")
}

model Orcamento {
  id           String   @id @default(uuid())
  osId         String   @unique
  status       String   @default("PENDENTE")
  valorPecas   Decimal  @default(0)
  valorMO      Decimal  @default(0)
  valorTotal   Decimal  @default(0)
  prazoEntrega DateTime?
  observacoes  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  os    OrdemServico    @relation(fields: [osId], references: [id], onDelete: Cascade)
  itens ItemOrcamento[]

  @@map("orcamentos")
}

model ItemOrcamento {
  id           String  @id @default(uuid())
  orcamentoId  String
  tipo         String
  descricao    String
  quantidade   Decimal
  valorUnit    Decimal
  valorTotal   Decimal
  fornecedorId String?

  orcamento  Orcamento   @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor? @relation(fields: [fornecedorId], references: [id])

  @@map("itens_orcamento")
}

model ItemOS {
  id         String  @id @default(uuid())
  osId       String
  tipo       String
  descricao  String
  quantidade Decimal
  valorUnit  Decimal
  valorTotal Decimal

  os OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@map("itens_os")
}

model Fornecedor {
  id       String  @id @default(uuid())
  nome     String
  cnpj     String?
  contato  String?
  telefone String?
  email    String?
  ativo    Boolean  @default(true)
  createdAt DateTime @default(now())

  itens        ItemOrcamento[]
  notasFiscais NotaFiscal[]

  @@map("fornecedores")
}

model HistoricoOS {
  id           String    @id @default(uuid())
  osId         String
  statusAntes  String?
  statusDepois String
  obs          String?
  usuarioNome  String?
  createdAt    DateTime  @default(now())

  os OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@map("historico_os")
}

// ─────────────────────────────────────────────
// FINANCEIRO
// ─────────────────────────────────────────────

model Pagamento {
  id           String   @id @default(uuid())
  osId         String
  metodo       String
  adquirente   String?
  nsu          String?
  valor        Decimal
  qtdParcelas  Int      @default(1)
  statusConcil String   @default("PENDENTE")
  createdAt    DateTime @default(now())

  os           OrdemServico     @relation(fields: [osId], references: [id])
  parcelas     ParcelaReceber[]
  conciliacoes Conciliacao[]

  @@map("pagamentos")
}

model ParcelaReceber {
  id           String    @id @default(uuid())
  pagamentoId  String
  numero       Int
  valor        Decimal
  dataPrevista DateTime
  dataRecebida DateTime?
  conciliado   Boolean   @default(false)
  lancamentoId String?

  pagamento  Pagamento          @relation(fields: [pagamentoId], references: [id], onDelete: Cascade)
  lancamento LancamentoExtrato? @relation(fields: [lancamentoId], references: [id])

  @@map("parcelas_receber")
}

model LancamentoExtrato {
  id          String   @id @default(uuid())
  origem      String
  data        DateTime
  descricao   String
  valor       Decimal
  nsuRef      String?
  conciliado  Boolean  @default(false)
  importadoEm DateTime @default(now())
  hashUnico   String   @unique

  parcelas     ParcelaReceber[]
  conciliacoes Conciliacao[]

  @@map("lancamentos_extrato")
}

model Conciliacao {
  id           String   @id @default(uuid())
  pagamentoId  String
  lancamentoId String
  valorConcil  Decimal
  tipoMatch    String
  createdAt    DateTime @default(now())

  pagamento  Pagamento         @relation(fields: [pagamentoId], references: [id])
  lancamento LancamentoExtrato @relation(fields: [lancamentoId], references: [id])

  @@map("conciliacoes")
}

model LancamentoCaixa {
  id        String   @id @default(uuid())
  tipo      String
  valor     Decimal
  descricao String
  osId      String?
  data      DateTime @default(now())
  createdAt DateTime @default(now())

  @@map("lancamentos_caixa")
}

model ItemInventario {
  id               String   @id @default(uuid())
  nome             String
  codigoInterno    String?
  codigoFabricante String?
  codigoBarras     String?
  categoria        String   @default("OUTROS")
  marca            String?
  compatibilidade  String?
  descricao        String?
  unidade          String   @default("UN")
  quantidade       Int      @default(0)
  qtdMinima        Int      @default(1)
  custoUnitario    Decimal  @default(0)
  precoVenda       Decimal  @default(0)
  localizacao      String?
  ativo            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  movimentacoes MovimentacaoEstoque[]
  itensNF       ItemNotaFiscal[]

  @@map("inventario")
}

model MovimentacaoEstoque {
  id         String   @id @default(uuid())
  itemId     String
  tipo       String
  quantidade Int
  motivo     String?
  osId       String?
  custo      Decimal  @default(0)
  createdAt  DateTime @default(now())

  item ItemInventario @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("movimentacoes_estoque")
}

model ContaPagar {
  id             String    @id @default(uuid())
  descricao      String
  categoria      String    @default("OUTROS")
  valor          Decimal
  dataVencimento DateTime
  dataPagamento  DateTime?
  status         String    @default("PENDENTE")
  observacoes    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("contas_pagar")
}

model NotaFiscal {
  id           String    @id @default(uuid())
  numero       String
  serie        String?
  fornecedorId String?
  dataEmissao  DateTime
  valorTotal   Decimal   @default(0)
  fotoPath     String?
  observacoes  String?
  status       String    @default("PENDENTE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  fornecedor Fornecedor?      @relation(fields: [fornecedorId], references: [id])
  itens      ItemNotaFiscal[]

  @@map("notas_fiscais")
}

model ItemNotaFiscal {
  id               String  @id @default(uuid())
  notaFiscalId     String
  descricao        String
  quantidade       Decimal
  valorUnitario    Decimal
  codigoFabricante String?
  itemInventarioId String?

  notaFiscal     NotaFiscal      @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  itemInventario ItemInventario? @relation(fields: [itemInventarioId], references: [id])

  @@map("itens_nota_fiscal")
}

// ─────────────────────────────────────────────
// HISTÓRICO DE MANUTENÇÃO
// ─────────────────────────────────────────────

model ManutencaoVeiculo {
  id            String    @id @default(uuid())
  veiculoId     String
  tipo          String
  descricao     String?
  kmRealizado   Int?
  dataRealizado DateTime
  kmProxima     Int?
  dataProxima   DateTime?
  osNumero      Int?
  createdAt     DateTime  @default(now())

  veiculo Veiculo          @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  fotos   FotoManutencao[]

  @@map("manutencoes_veiculo")
}

model FotoManutencao {
  id           String   @id @default(uuid())
  manutencaoId String
  tipo         String   @default("GERAL")
  filename     String
  createdAt    DateTime @default(now())

  manutencao ManutencaoVeiculo @relation(fields: [manutencaoId], references: [id], onDelete: Cascade)

  @@map("fotos_manutencao")
}

// ─────────────────────────────────────────────
// FILIAIS
// ─────────────────────────────────────────────

model Filial {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String?
  endereco  String?
  telefone  String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios Usuario[]
  ordens   OrdemServico[]

  @@map("filiais")
}

// ─────────────────────────────────────────────
// TABELA DE SERVIÇOS
// ─────────────────────────────────────────────

model Servico {
  id           String   @id @default(uuid())
  nome         String   @unique
  descricao    String?
  duracaoHoras Float    @default(1)
  precoBase    Float    @default(0)
  precoHora    Float    @default(0)
  ativo        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ordens OrdemServico[]

  @@map("servicos")
}

// ─────────────────────────────────────────────
// TÉCNICOS
// ─────────────────────────────────────────────

model Tecnico {
  id        String   @id @default(uuid())
  nome      String
  matricula String?
  cargo     String   @default("MECANICO")
  telefone  String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tecnicos")
}

// ─────────────────────────────────────────────
// CHECKLIST DE SUGESTÕES IA
// ─────────────────────────────────────────────

model SugestaoIA {
  id         String   @id @default(uuid())
  osId       String
  descricao  String
  prioridade String   @default("MEDIA")
  feito      Boolean  @default(false)
  ordem      Int      @default(0)
  createdAt  DateTime @default(now())

  os OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@map("sugestoes_ia")
}

// ─────────────────────────────────────────────
// AVALIAÇÃO PÓS-SERVIÇO (NPS)
// ─────────────────────────────────────────────

model Avaliacao {
  id           String    @id @default(uuid())
  osId         String    @unique
  token        String    @unique
  nota         Int?
  comentario   String?
  respondidoEm DateTime?
  createdAt    DateTime  @default(now())

  os OrdemServico @relation(fields: [osId], references: [id], onDelete: Cascade)

  @@map("avaliacoes")
}
