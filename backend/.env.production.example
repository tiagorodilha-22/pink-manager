# ── Banco de dados (Cloud SQL — Postgres) ────────────────────────────────────
# Formato Cloud SQL via proxy Unix socket:
#   postgresql://USER:PASS@localhost/DB?host=/cloudsql/PROJECT:REGION:INSTANCE
# Formato TCP direto (VPC ou Cloud SQL Auth Proxy):
#   postgresql://USER:PASS@HOST:5432/DB
DATABASE_URL=postgresql://pink:SENHA@/pink_manager?host=/cloudsql/MEU_PROJETO_ID:southamerica-east1:pink-db-prod

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=uma_chave_aleatoria_longa_e_segura

# ── Arquivos (Google Cloud Storage) ──────────────────────────────────────────
# Nome do bucket (sem gs://)
GCS_BUCKET=pink-manager-uploads

# ── Identidade da oficina ─────────────────────────────────────────────────────
NOME_OFICINA=Nome da Oficina
FRONTEND_URL=https://juane-soc-prod.web.app

# ── E-mail (opcional) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=oficina@gmail.com
SMTP_PASS=app_password_aqui
SMTP_FROM=oficina@gmail.com

# ── WhatsApp via Z-API (opcional) ─────────────────────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── IA (opcional) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
